# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# These credentials are used by the PostgreSQL Docker container on initialization
POSTGRES_DB=trackscendence
POSTGRES_PASSWORD=changeme
POSTGRES_USER=trackscendence

# Port exposed to the host machine for direct database access (e.g., via DBeaver)
DB_PORT=5432

# Prisma database connection string used by the Node backend
# This internally references the Postgres container on the Docker network
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
# The port the Express application listens on inside the container
PORT=3001

# The port exposed to your host machine for the backend API during development
SERVER_PORT=3001

# Environment mode (development/production)
NODE_ENV=production

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# JWT Security - MUST BE CHANGED IN PRODUCTION!
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_EXPIRES_IN=7d
JWT_SECRET=replace-with-a-secure-random-secret

# Rate limiting for API requests (e.g., 100 requests per 15 minutes)
RATE_LIMIT_LIMIT=100
RATE_LIMIT_WINDOW_MS=900000

# Cross-Origin Resource Sharing (CORS)
# Determines which frontend origins are allowed to call the backend API
CORS_ORIGIN=http://localhost:5173

# ==============================================================================
# CLIENT (FRONTEND) CONFIGURATION
# ==============================================================================
# The base URL path where the frontend proxies API requests
VITE_API_URL=/api

# The port Nginx uses to serve the built frontend in production mode
CLIENT_PORT=8080

# The port Vite uses for hot-reloading the frontend in development mode
CLIENT_DEV_PORT=5173

# ==============================================================================
# OPTIONAL: EMAIL & APP OVERRIDES
# ==============================================================================
# Uncomment and configure these if you are testing email flows like Password Reset
# APP_BASE_URL=http://localhost:8080
# PASSWORD_RESET_URL_BASE=http://localhost:8080/reset-password
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Trackscendence <no-reply@example.com>
