# Database
POSTGRES_USER=trackscendence
POSTGRES_PASSWORD=changeme
POSTGRES_DB=trackscendence
DB_PORT=5432

# Server
PORT=3001
SERVER_PORT=3001
NODE_ENV=production
LOG_LEVEL=info
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}
JWT_SECRET=replace-with-a-secure-random-secret
# Access token lifetime for the current milestone. Keep in sync with server/utils/config.js.
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LIMIT=100

# Optional app URL / mail overrides
# APP_BASE_URL=http://localhost:8080
# PASSWORD_RESET_URL_BASE=http://localhost:8080/reset-password
# TWO_FACTOR_CHALLENGE_EXPIRES_IN=5m
TWO_FACTOR_ENCRYPTION_SECRET=replace-with-a-separate-secret
# TWO_FACTOR_ISSUER=Trackscendence
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Trackscendence <no-reply@example.com>

# Client build-time
VITE_API_URL=/api
CLIENT_PORT=8080
CLIENT_DEV_PORT=5173
