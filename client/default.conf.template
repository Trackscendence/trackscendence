# Plain-HTTP edge. This is the whole story when TLS is off (the default, and
# how Railway runs, terminating TLS at its own edge). When ENABLE_TLS=1 the
# entrypoint (50-tls.sh) overwrites this rendered file with a 301 redirect to
# the HTTPS origin, so 8080 still lands somewhere sensible.
server {
    listen 8080;
    server_name localhost;
    include /etc/nginx/conf.d/app-locations.inc;
}
