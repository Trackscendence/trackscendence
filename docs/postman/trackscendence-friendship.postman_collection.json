        {
          "name": "Requester Cannot Send Duplicate Pending Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('duplicate pending request returns 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "const json = pm.response.json();",
