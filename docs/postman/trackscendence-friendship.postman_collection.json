{
  "info": {
    "_postman_id": "ef4f9d31-7d0b-4527-9c91-2cc58f36e44c",
    "name": "Trackscendence Friendship Flow",
    "description": "End-to-end friendship flow checks for the local Trackscendence Docker stack. Run the collection from top to bottom, or at minimum run 'Initialize Friendship Variables' first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Initialize",
      "item": [
        {
          "name": "Initialize Friendship Variables",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "pm.environment.set('runId', runId);",
                  "pm.environment.set('friendPassword', 'Start123!');",
                  "pm.environment.set('friendRequesterEmail', `friend.requester.${runId}@example.com`);",
                  "pm.environment.set('friendRequesterUsername', `friend_requester_${runId}`);",
                  "pm.environment.set('friendAddresseeEmail', `friend.addressee.${runId}@example.com`);",
                  "pm.environment.set('friendAddresseeUsername', `friend_addressee_${runId}`);",
                  "pm.environment.set('friendMissingUserId', '999999999');",
                  "pm.environment.unset('friendRequesterUserId');",
                  "pm.environment.unset('friendRequesterToken');",
                  "pm.environment.unset('friendAddresseeUserId');",
                  "pm.environment.unset('friendAddresseeToken');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ping returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('friendship test variables were generated', function () {",
                  "  pm.expect(pm.environment.get('friendRequesterEmail')).to.include('@example.com');",
                  "  pm.expect(pm.environment.get('friendAddresseeEmail')).to.include('@example.com');",
                  "  pm.expect(pm.environment.get('friendRequesterUsername')).to.include('friend_requester_');",
                  "  pm.expect(pm.environment.get('friendAddresseeUsername')).to.include('friend_addressee_');",
                  "  pm.expect(pm.environment.get('friendMissingUserId')).to.eql('999999999');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ping",
            "description": "Generates a fresh pair of users and clears all saved friendship auth variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Register And Login Users",
      "item": [
        {
          "name": "Register Requester",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register requester returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('friendRequesterUserId', String(json.user.id));",
                  "pm.test('register requester returns generated identity', function () {",
                  "  pm.expect(json.user.email).to.eql(pm.environment.get('friendRequesterEmail'));",
                  "  pm.expect(json.user.username).to.eql(pm.environment.get('friendRequesterUsername'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{friendRequesterEmail}}\",\n  \"username\": \"{{friendRequesterUsername}}\",\n  \"password\": \"{{friendPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
        },
        {
          "name": "Login Requester",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
