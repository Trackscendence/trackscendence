                  "pm.test('requester no longer sees addressee as friend', function () {",
                  "  const match = json.friends.find((item) => String(item.user.id) === pm.environment.get('friendAddresseeUserId'));",
                  "  pm.expect(match).to.not.exist;",
                  "});"
                ]
              }
            }
