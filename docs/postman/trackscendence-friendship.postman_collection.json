                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('friendRequesterToken', json.token);",
                  "pm.test('requester token was saved', function () {",
                  "  pm.expect(pm.environment.get('friendRequesterToken')).to.be.a('string').and.not.empty;",
                  "});"
