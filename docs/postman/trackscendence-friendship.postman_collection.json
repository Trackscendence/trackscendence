    {
      "name": "03 Accept And Remove Flow",
      "item": [
        {
          "name": "Requester Sends Friend Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('friend request returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('friend request message is returned', function () {",
                  "  pm.expect(json.message).to.eql('Friend request sent successfully');",
                  "});",
                  "pm.test('request points to addressee user', function () {",
                  "  pm.expect(String(json.request.user.id)).to.eql(pm.environment.get('friendAddresseeUserId'));",
                  "  pm.expect(json.request.status).to.eql('PENDING');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{friendRequesterToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetUserId\": {{friendAddresseeUserId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
