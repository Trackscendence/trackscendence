{
  "scripts": {
    "prepare": "husky",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "client:dev": "cross-env VITE_API_PROXY_TARGET=http://localhost:3001 npm run dev --prefix client",
    "server:dev": "npm run dev --prefix server",
    "dev": "concurrently \"npm:client:dev\" \"npm:server:dev\"",
    "lint": "npm run lint:client",
    "lint:client": "npm run lint --prefix client",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spellcheck": "cspell .",
    "build": "npm run build --prefix client",
    "start": "npm start --prefix server",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:dev": "docker compose -f compose.yaml -f compose.dev.yaml up --build",
    "compose:dev_down": "docker compose -f compose.yaml -f compose.dev.yaml down",
    "compose:build": "docker compose build",
    "compose:logs": "docker compose logs -f",
    "compose:clean": "docker compose down -v",
    "db:shell": "docker compose exec database psql -U trackscendence -d trackscendence",
    "prisma:generate": "docker compose exec server npm run prisma:generate",
    "prisma:migrate": "docker compose exec server npm run prisma:migrate",
    "storybook": "npm run storybook --prefix client",
    "build-storybook": "npm run build-storybook --prefix client"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
