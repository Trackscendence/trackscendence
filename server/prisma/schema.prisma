generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../../docs/ERD.md"
  theme    = "neutral"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                      Int      @id @default(autoincrement())
  email                   String   @unique
  username                String   @unique
  passwordHash            String
  passwordResetTokenId    String?  @unique
  passwordResetTokenHash  String?
  passwordResetTokenExpiry DateTime?
  tokenVersion            Int      @default(0)
  twoFactorChallengeVersion Int    @default(0)
  twoFactorEnabled        Boolean  @default(false)
  twoFactorSecretCiphertext String?
  twoFactorPendingSecretCiphertext String?
  role                    Role     @default(USER)
  twoFactorRecoveryCodes  UserTwoFactorRecoveryCode[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  games                   GamePlayer[]
  outgoingFriendships     Friendship[] @relation("FriendshipRequester")
  incomingFriendships     Friendship[] @relation("FriendshipAddressee")
  friendshipsBlockedByUser Friendship[] @relation("FriendshipBlocker")
  failedLoginCount        Int      @default(0)
  lockedOutUntil          DateTime?
}

model UserTwoFactorRecoveryCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  codeHash  String
  isPending Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId, isPending])
}

enum GameStatus {
  COMPLETED
  ABANDONED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Game {
  id          Int          @id @default(autoincrement())
  status      GameStatus   @default(COMPLETED)
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  players     GamePlayer[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GamePlayer {
  id          Int      @id @default(autoincrement())
  gameId      Int
  userId      Int
  score       Int      @default(0)
  isWinner    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  game        Game     @relation(fields: [gameId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
  @@index([userId])
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      FriendshipStatus @default(PENDING)
  blockedById Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  blockedBy   User?            @relation("FriendshipBlocker", fields: [blockedById], references: [id], onDelete: SetNull)

  // This is an explicit relationship entity, not an implicit many-to-many table,
  // because we need lifecycle state (PENDING / ACCEPTED / BLOCKED), timestamps,
  // and knowledge of who initiated or blocked the relationship.
  // A follow-up SQL migration also enforces unordered-pair uniqueness via LEAST/GREATEST.
  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@index([blockedById])
}
