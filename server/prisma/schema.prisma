generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../../docs/ERD.md"
  theme    = "neutral"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id                               Int                         @id @default(autoincrement())
  email                            String                      @unique
  username                         String                      @unique
  displayName                      String?
  bio                              String?
  avatarUrl                        String?
  // Null for accounts provisioned through 42 OAuth that never set a password;
  // password login and change-password are rejected until a reset sets one.
  passwordHash                     String?
  fortyTwoId                       Int?                        @unique
  passwordResetTokenId             String?                     @unique
  passwordResetTokenHash           String?
  passwordResetTokenExpiry         DateTime?
  tokenVersion                     Int                         @default(0)
  termsAcceptedAt                  DateTime?
  privacyAcceptedAt                DateTime?
  deletedAt                        DateTime?
  isGuest                          Boolean                     @default(false)
  isBot                            Boolean                     @default(false)
  gamesPlayed                      Int                         @default(0)
  wins                             Int                         @default(0)
  losses                           Int                         @default(0)
  rank                             Int?
  twoFactorChallengeVersion        Int                         @default(0)
  twoFactorEnabled                 Boolean                     @default(false)
  twoFactorSecretCiphertext        String?
  twoFactorPendingSecretCiphertext String?
  role                             Role                        @default(USER)
  status                           UserStatus                  @default(ACTIVE)
  statusReason                     String?
  suspendedUntil                   DateTime?
  statusUpdatedAt                  DateTime?
  twoFactorRecoveryCodes           UserTwoFactorRecoveryCode[]
  createdAt                        DateTime                    @default(now())
  updatedAt                        DateTime                    @updatedAt
  games                            GamePlayer[]
  outgoingFriendships              Friendship[]                @relation("FriendshipRequester")
  incomingFriendships              Friendship[]                @relation("FriendshipAddressee")
  friendshipsBlockedByUser         Friendship[]                @relation("FriendshipBlocker")
  failedLoginCount                 Int                         @default(0)
  lockedOutUntil                   DateTime?
  ownedRooms                       Room[]                      @relation("RoomOwner")
  roomMemberships                  RoomPlayer[]
  createdChatRooms                 ChatRoom[]                  @relation("ChatRoomCreator")
  chatRoomMemberships              ChatRoomMember[]
  chatRoomInvitesSent              ChatRoomMember[]            @relation("ChatRoomInviter")
  chatMessages                     ChatMessage[]
  directConversationAsFirstUser    DirectConversation[]        @relation("DirectConversationFirstUser")
  directConversationAsSecondUser   DirectConversation[]        @relation("DirectConversationSecondUser")
  directMessages                   DirectMessage[]
  socialNotifications              SocialNotification[]        @relation("SocialNotificationRecipient")
  socialNotificationsTriggered     SocialNotification[]        @relation("SocialNotificationActor")
  apiKeys                          ApiKey[]
  tournamentsCreated               Tournament[]                @relation("TournamentCreator")
  tournamentsWon                   Tournament[]                @relation("TournamentWinner")
  tournamentEntries                TournamentPlayer[]
  tournamentMatchesAsPlayerA       TournamentMatch[]           @relation("TournamentMatchPlayerA")
  tournamentMatchesAsPlayerB       TournamentMatch[]           @relation("TournamentMatchPlayerB")
  tournamentMatchesWon             TournamentMatch[]           @relation("TournamentMatchWinner")

  @@index([deletedAt])
  @@index([isBot])
  @@index([status])
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  userId     Int
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Only the SHA-256 hash of the key is stored; the plaintext key is shown to
  // the owner once at creation time. Revocation is a soft delete (revokedAt)
  // so issued keys stay auditable.
  @@index([userId])
}

model UserTwoFactorRecoveryCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  codeHash  String
  isPending Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId, isPending])
}

enum GameStatus {
  COMPLETED
  ABANDONED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum SocialNotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  DIRECT_MESSAGE
  TOURNAMENT_JOINED
}

model Game {
  id                Int               @id @default(autoincrement())
  status            GameStatus        @default(COMPLETED)
  startedAt         DateTime          @default(now())
  endedAt           DateTime?
  players           GamePlayer[]
  tournamentMatches TournamentMatch[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Recent-match history (profile page) filters GamePlayer by userId then orders
  // by Game.endedAt desc. Index the sort column so the join does not fall back to
  // a sort with no index as the games table grows.
  @@index([endedAt])
}

model GamePlayer {
  id        Int      @id @default(autoincrement())
  gameId    Int
  userId    Int
  score     Int      @default(0)
  isWinner  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game Game @relation(fields: [gameId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
  @@index([userId])
}

enum RoomStatus {
  OPEN
  IN_GAME
  CLOSED
}

enum ChatRoomVisibility {
  PUBLIC
  INVITE_ONLY
}

enum ChatRoomMemberRole {
  ADMIN
  MEMBER
}

enum ChatRoomMemberStatus {
  INVITED
  ACTIVE
  LEFT
  KICKED
}

model Room {
  id        Int        @id @default(autoincrement())
  name      String
  capacity  Int
  status    RoomStatus @default(OPEN)
  ownerId   Int
  // Live games are keyed by a runtime UUID and only flushed to the Game table
  // once they end (see docs/adr/0001-in-memory-game-state.md), so this is the
  // runtime game id, not a foreign key to Game.
  gameId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  owner   User         @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  players RoomPlayer[]

  @@index([status])
  @@index([ownerId, status])
}

model RoomPlayer {
  id        Int      @id @default(autoincrement())
  roomId    Int
  userId    Int
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

enum TournamentStatus {
  OPEN
  RUNNING
  COMPLETED
  CANCELLED
}

model Tournament {
  id           Int              @id @default(autoincrement())
  name         String
  status       TournamentStatus @default(OPEN)
  // Bracket size, 4 or 8 in v1 (validated in the service).
  size         Int
  prizePoints  Int              @default(0)
  // 0 while OPEN, 1-based once RUNNING.
  currentRound Int              @default(0)
  totalRounds  Int
  createdById  Int
  winnerId     Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  createdBy User               @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  winner    User?              @relation("TournamentWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  players   TournamentPlayer[]
  matches   TournamentMatch[]

  // The list endpoint filters by status and sorts newest first.
  @@index([status, createdAt])
  @@index([createdById])
}

model TournamentPlayer {
  id           Int       @id @default(autoincrement())
  tournamentId Int
  userId       Int
  // Assigned when the bracket locks (start).
  seed         Int?
  // Set when the player loses a match.
  eliminatedAt DateTime?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  // Hot read: a user's active tournament.
  @@index([userId])
}

model TournamentMatch {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  // 1-based round number.
  round        Int
  // 0-based position within the round.
  slot         Int
  playerAId    Int?
  playerBId    Int?
  winnerId     Int?
  // Runtime UUID of the live in-memory game, same convention as Room.gameId.
  liveGameId   String?
  // Persisted Game row once the match's game has been flushed to Postgres.
  gameId       Int?
  // DB Room hosting this match while it is being played.
  roomId       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament  Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerA     User?      @relation("TournamentMatchPlayerA", fields: [playerAId], references: [id], onDelete: SetNull)
  playerB     User?      @relation("TournamentMatchPlayerB", fields: [playerBId], references: [id], onDelete: SetNull)
  matchWinner User?      @relation("TournamentMatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  game        Game?      @relation(fields: [gameId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, round, slot])
  // The bracket read is by tournament (covered by the unique above); the result
  // bridge looks a match up by its live game id when the in-memory game ends.
  @@index([liveGameId])
}

model Friendship {
  id             Int              @id @default(autoincrement())
  requesterId    Int
  addresseeId    Int
  status         FriendshipStatus @default(PENDING)
  requestMessage String?
  blockedById    Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  requester          User           @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee          User           @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  blockedBy          User?          @relation("FriendshipBlocker", fields: [blockedById], references: [id], onDelete: SetNull)
  introDirectMessage DirectMessage? @relation("DirectMessageFriendshipRequest")

  // This is an explicit relationship entity, not an implicit many-to-many table,
  // because we need lifecycle state (PENDING / ACCEPTED / BLOCKED), timestamps,
  // and knowledge of who initiated or blocked the relationship.
  // A follow-up SQL migration also enforces unordered-pair uniqueness via LEAST/GREATEST.
  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@index([blockedById])
}

model ChatRoom {
  id          Int                @id @default(autoincrement())
  name        String
  visibility  ChatRoomVisibility @default(PUBLIC)
  createdById Int
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  createdBy   User             @relation("ChatRoomCreator", fields: [createdById], references: [id], onDelete: Cascade)
  memberships ChatRoomMember[]
  messages    ChatMessage[]

  @@index([visibility])
  @@index([createdById])
}

model ChatRoomMember {
  id          Int                  @id @default(autoincrement())
  roomId      Int
  userId      Int
  role        ChatRoomMemberRole   @default(MEMBER)
  status      ChatRoomMemberStatus @default(ACTIVE)
  isMuted     Boolean              @default(false)
  invitedById Int?
  joinedAt    DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?    @relation("ChatRoomInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([roomId, userId])
  @@index([userId, status])
  @@index([roomId, status])
  @@index([invitedById])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  roomId    Int
  userId    Int
  message   String
  createdAt DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([userId])
}

model DirectConversation {
  id                Int       @id @default(autoincrement())
  userOneId         Int
  userTwoId         Int
  userOneLastReadAt DateTime?
  userTwoLastReadAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  userOne       User                 @relation("DirectConversationFirstUser", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo       User                 @relation("DirectConversationSecondUser", fields: [userTwoId], references: [id], onDelete: Cascade)
  messages      DirectMessage[]
  notifications SocialNotification[]

  @@unique([userOneId, userTwoId])
  @@index([userTwoId])
  @@index([updatedAt])
}

model DirectMessage {
  id                  Int      @id @default(autoincrement())
  conversationId      Int
  senderId            Int
  friendshipRequestId Int?     @unique
  message             String
  createdAt           DateTime @default(now())

  conversation      DirectConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
  friendshipRequest Friendship?          @relation("DirectMessageFriendshipRequest", fields: [friendshipRequestId], references: [id], onDelete: SetNull)
  notifications     SocialNotification[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model SocialNotification {
  id              Int                    @id @default(autoincrement())
  userId          Int
  actorId         Int?
  type            SocialNotificationType
  message         String?
  conversationId  Int?
  directMessageId Int?
  readAt          DateTime?
  createdAt       DateTime               @default(now())

  user          User                @relation("SocialNotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor         User?               @relation("SocialNotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  conversation  DirectConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  directMessage DirectMessage?      @relation(fields: [directMessageId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([actorId])
  @@index([conversationId])
  @@index([directMessageId])
}
