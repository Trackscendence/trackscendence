    {
      "name": "03 Two-Factor Authentication",
      "item": [
        {
          "name": "Start Two-Factor Setup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('2FA setup returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('twoFactorSecret', json.setup.manualEntryKey);",
                  "pm.environment.set('recoveryCode', json.setup.recoveryCodes[0]);",
                  "pm.environment.set('backupRecoveryCode', json.setup.recoveryCodes[1]);",
                  "pm.test('2FA setup returns setup payload', function () {",
                  "  pm.expect(json.message).to.eql('Two-factor authentication setup started');",
                  "  pm.expect(json.setup.manualEntryKey).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.setup.qrCodeDataUrl).to.include('data:image/png;base64');",
                  "  pm.expect(json.setup.recoveryCodes).to.be.an('array').with.lengthOf(8);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/two-factor/setup"
          },
          "response": []
        },
        {
          "name": "Confirm Two-Factor Setup",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const secret = (pm.environment.get('twoFactorSecret') || '').toUpperCase().replace(/=+$/g, '').replace(/[^A-Z2-7]/g, '');",
                  "const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';",
                  "let bits = '';",
                  "for (const character of secret) {",
                  "  const index = alphabet.indexOf(character);",
                  "  pm.expect(index, `invalid base32 character: ${character}`).to.not.eql(-1);",
                  "  bits += index.toString(2).padStart(5, '0');",
                  "}",
                  "let hex = '';",
                  "for (let index = 0; index + 8 <= bits.length; index += 8) {",
                  "  hex += Number.parseInt(bits.slice(index, index + 8), 2).toString(16).padStart(2, '0');",
                  "}",
                  "const key = CryptoJS.enc.Hex.parse(hex);",
                  "const counter = Math.floor(Date.now() / 1000 / 30);",
                  "const counterHex = counter.toString(16).padStart(16, '0');",
                  "const message = CryptoJS.enc.Hex.parse(counterHex);",
                  "const digest = CryptoJS.HmacSHA1(message, key).toString(CryptoJS.enc.Hex);",
                  "const offset = Number.parseInt(digest.slice(-1), 16);",
                  "const binary = Number.parseInt(digest.slice(offset * 2, offset * 2 + 8), 16) & 0x7fffffff;",
                  "const code = String(binary % 1000000).padStart(6, '0');",
                  "pm.environment.set('twoFactorCode', code);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('2FA confirm returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('2FA confirm enables 2FA', function () {",
                  "  pm.expect(json.message).to.eql('Two-factor authentication enabled successfully');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{twoFactorCode}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/two-factor/confirm"
          },
          "response": []
        },
        {
          "name": "Login Returns Two-Factor Challenge",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login challenge returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('challengeToken', json.challengeToken);",
                  "pm.test('login challenge requires second factor', function () {",
                  "  pm.expect(json.requiresTwoFactor).to.eql(true);",
                  "  pm.expect(json.methods).to.include('totp');",
                  "  pm.expect(json.methods).to.include('recovery_code');",
                  "  pm.expect(pm.environment.get('challengeToken')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
