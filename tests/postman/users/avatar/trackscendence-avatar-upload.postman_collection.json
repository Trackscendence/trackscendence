          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{avatarToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": "{{avatarUnsupportedPath}}"
                }
              ]
            },
            "url": "{{baseUrl}}/users/me/avatar"
          },
          "response": []
        },
        {
          "name": "Reject Invalid PNG Contents",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('invalid PNG contents return 400', function () {",
                  "  pm.response.to.have.status(400);",
