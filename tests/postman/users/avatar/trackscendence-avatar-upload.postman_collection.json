    },
    {
      "name": "05 Delete Avatar",
      "item": [
        {
          "name": "Delete Current Avatar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('delete avatar returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('delete avatar clears avatarUrl', function () {",
                  "  pm.expect(json.message).to.eql('Avatar removed successfully');",
                  "  pm.expect(json.user.avatarUrl).to.eql(null);",
                  "});",
                  "pm.environment.unset('avatarUploadedUrl');",
                  "pm.environment.unset('avatarReplacedUrl');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{avatarToken}}"
              }
            ],
            "url": "{{baseUrl}}/users/me/avatar"
          },
          "response": []
        },
        {
          "name": "Auth Me After Delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('me returns 200 after delete', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('me response clears avatarUrl', function () {",
                  "  pm.expect(json.user.avatarUrl).to.eql(null);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{avatarToken}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          },
          "response": []
        },
        {
          "name": "Public Profile After Delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('public profile returns 200 after delete', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('public profile clears avatarUrl after delete', function () {",
                  "  pm.expect(json.user.username).to.eql(pm.environment.get('avatarUsername'));",
                  "  pm.expect(json.user.avatarUrl).to.eql(null);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{avatarUsername}}"
          },
          "response": []
        }
      ]
    }
  ]
}
