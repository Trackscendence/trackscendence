                  "pm.test('invalid PNG contents error is clear', function () {",
                  "  pm.expect(json.error.message).to.eql('Avatar file contents must be a valid JPEG or PNG image');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{avatarToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": "{{avatarInvalidPngPath}}"
                }
              ]
            },
            "url": "{{baseUrl}}/users/me/avatar"
          },
          "response": []
        },
        {
          "name": "Reject Oversized Avatar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('oversized file returns 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('oversized file error is clear', function () {",
                  "  pm.expect(json.error.message).to.eql('Avatar must not exceed 2 MB');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{avatarToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": "{{avatarOversizePngPath}}"
                }
              ]
            },
            "url": "{{baseUrl}}/users/me/avatar"
          },
          "response": []
        },
        {
          "name": "Reject Unexpected File Field",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('unexpected file field returns 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
