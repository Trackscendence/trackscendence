          "name": "Reject Avatar Upload Without Auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('upload without auth returns 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('upload without auth uses standard auth error', function () {",
