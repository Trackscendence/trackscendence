{
  "info": {
    "_postman_id": "2a8bb1e6-5a8a-41d1-8cc5-f255c7d1225d",
    "name": "Trackscendence Profile And Stats",
    "description": "Profile lookup and profile-update checks for the local Trackscendence Docker stack. Run the collection from top to bottom, or at minimum run 'Initialize Profile Variables' first. Stats and match-history assertions here focus on the zero-state API contract; see the README for the optional saved-game seeding step.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Initialize",
      "item": [
        {
          "name": "Initialize Profile Variables",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "const usernameSuffix = runId.slice(-8);",
                  "pm.environment.set('runId', runId);",
                  "pm.environment.set('profileEmail', `${pm.environment.get('profileEmailPrefix')}.${runId}@example.com`);",
                  "pm.environment.set('profileUsername', `${pm.environment.get('profileUsernamePrefix')}${usernameSuffix}`);",
                  "pm.environment.set('profileOpponentEmail', `${pm.environment.get('profileOpponentEmailPrefix')}.${runId}@example.com`);",
                  "pm.environment.set('profileOpponentUsername', `${pm.environment.get('profileOpponentUsernamePrefix')}${usernameSuffix}`);",
                  "pm.environment.set('profileMissingUsername', `${pm.environment.get('profileMissingUsernamePrefix')}${usernameSuffix}`);",
                  "pm.environment.unset('profileOwnerId');",
                  "pm.environment.unset('profileOpponentId');",
                  "pm.environment.unset('profileToken');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ping returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('profile variables were generated', function () {",
                  "  pm.expect(pm.environment.get('profileEmail')).to.include('@example.com');",
                  "  pm.expect(pm.environment.get('profileUsername')).to.include('profileplayer');",
                  "  pm.expect(pm.environment.get('profileOpponentUsername')).to.include('profileopponent');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ping",
            "description": "Generates a fresh pair of usernames/emails and clears saved profile auth variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Register And Login",
      "item": [
        {
          "name": "Register Profile Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register owner returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('profileOwnerId', String(json.user.id));",
                  "pm.test('register owner returns the generated identity', function () {",
                  "  pm.expect(json.user.email).to.eql(pm.environment.get('profileEmail'));",
                  "  pm.expect(json.user.username).to.eql(pm.environment.get('profileUsername'));",
                  "});",
                  "pm.test('new owner starts with zero stats', function () {",
                  "  pm.expect(json.user.gamesPlayed).to.eql(0);",
                  "  pm.expect(json.user.wins).to.eql(0);",
                  "  pm.expect(json.user.losses).to.eql(0);",
                  "  pm.expect(json.user.rank).to.eql(null);",
                  "});",
                  "pm.test('register owner response does not include secrets', function () {",
                  "  pm.expect(JSON.stringify(json)).to.not.include('passwordHash');",
                  "  pm.expect(JSON.stringify(json)).to.not.include('passwordResetTokenHash');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{profileEmail}}\",\n  \"username\": \"{{profileUsername}}\",\n  \"password\": \"{{profilePassword}}\",\n  \"termsAccepted\": true,\n  \"privacyAccepted\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
        },
        {
          "name": "Login Profile Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login owner returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('profileToken', json.token);",
                  "pm.test('login owner stores a bearer token', function () {",
                  "  pm.expect(pm.environment.get('profileToken')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{profileEmail}}\",\n  \"password\": \"{{profilePassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": []
        },
        {
          "name": "Get Current User Baseline",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('me returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('me reflects the new zero-state profile', function () {",
                  "  pm.expect(json.user.email).to.eql(pm.environment.get('profileEmail'));",
                  "  pm.expect(json.user.displayName).to.eql(null);",
                  "  pm.expect(json.user.bio).to.eql(null);",
                  "  pm.expect(json.user.gamesPlayed).to.eql(0);",
                  "  pm.expect(json.user.rank).to.eql(null);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{profileToken}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          },
          "response": []
        },
        {
          "name": "Register Profile Opponent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register opponent returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('profileOpponentId', String(json.user.id));",
                  "pm.test('register opponent returns the generated identity', function () {",
                  "  pm.expect(json.user.email).to.eql(pm.environment.get('profileOpponentEmail'));",
                  "  pm.expect(json.user.username).to.eql(pm.environment.get('profileOpponentUsername'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{profileOpponentEmail}}\",\n  \"username\": \"{{profileOpponentUsername}}\",\n  \"password\": \"{{profilePassword}}\",\n  \"termsAccepted\": true,\n  \"privacyAccepted\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
        }
      ]
