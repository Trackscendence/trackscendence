    {
      "name": "03 Public Profile Lookups",
      "item": [
        {
          "name": "Get Public Profile By Username",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('public profile returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('public profile returns the requested user', function () {",
                  "  pm.expect(json.user.username).to.eql(pm.environment.get('profileUsername'));",
                  "  pm.expect(json.user.displayName).to.eql(null);",
                  "});",
                  "pm.test('public profile does not expose private fields', function () {",
                  "  pm.expect(json.user.email).to.eql(undefined);",
                  "  pm.expect(json.user.role).to.eql(undefined);",
                  "  pm.expect(JSON.stringify(json)).to.not.include('passwordHash');",
                  "});",
                  "pm.test('public profile includes stats and recentMatches shape', function () {",
                  "  pm.expect(json.user.stats.gamesPlayed).to.eql(0);",
                  "  pm.expect(json.user.stats.wins).to.eql(0);",
                  "  pm.expect(json.user.stats.losses).to.eql(0);",
                  "  pm.expect(json.user.stats.rank).to.eql(null);",
                  "  pm.expect(json.user.recentMatches).to.be.an('array');",
                  "  pm.expect(json.user.recentMatches.length).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{profileUsername}}"
          },
          "response": []
        },
